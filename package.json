{
  "name": "login-with-chatgpt-for-cloudflare",
  "version": "0.2.0",
  "description": "Cloudflare Worker fork of opencoredev/login-with-chatgpt with encrypted SQLite Durable Object sessions.",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./crypto": "./src/crypto.ts",
    "./openai": "./src/openai.ts",
    "./session": "./src/session.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BradenHartsell/login-with-chatgpt-for-cloudflare.git"
  },
  "homepage": "https://github.com/BradenHartsell/login-with-chatgpt-for-cloudflare#readme",
  "bugs": {
    "url": "https://github.com/BradenHartsell/login-with-chatgpt-for-cloudflare/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run types && npm run typecheck && npm test && npm run deploy:dry-run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "@types/node": "^26.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
